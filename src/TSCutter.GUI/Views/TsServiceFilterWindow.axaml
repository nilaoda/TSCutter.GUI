<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:TSCutter.GUI.ViewModels"
        mc:Ignorable="d"
        x:Class="TSCutter.GUI.Views.TsServiceFilterWindow"
        x:DataType="viewModels:TsServiceFilterWindowViewModel"
        Title="{DynamicResource String.TsServiceFilter.Title}"
        Width="860" Height="560" MinWidth="720" MinHeight="440"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12" RowDefinitions="Auto,24,Auto,*,Auto" RowSpacing="8">
        <ClassicBorderDecorator Grid.Row="0" BorderThickness="1" BorderStyle="Etched" Padding="8">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource String.TsServiceFilter.File}" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FilePath}" IsReadOnly="True" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource String.TsServiceFilter.FileSize}" VerticalAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding FileSizeText}" FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource String.TsServiceFilter.Status}" VerticalAlignment="Center" />
                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding StatusText}" TextWrapping="Wrap" />
            </Grid>
        </ClassicBorderDecorator>

        <Grid Grid.Row="1" ColumnDefinitions="*,100" ColumnSpacing="8">
            <ProgressBar Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding Percent}"
                         IsVisible="{Binding ShowOutputProgress}" Height="18" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="{Binding Percent, StringFormat={}{0:0.00}%}"
                       IsVisible="{Binding ShowOutputProgress}" TextAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5" Text="{Binding ProbeSummaryText}"
                       TextWrapping="Wrap" Opacity="0.75" />
            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                <Run Text="{DynamicResource String.TsServiceFilter.Selected}" /><Run Text=" " />
                <Run Text="{Binding SelectedCount}" FontWeight="Bold" />
            </TextBlock>
            <Button Grid.Row="1" Grid.Column="1" Content="{DynamicResource String.TsServiceFilter.SelectAll}"
                    Command="{Binding SelectAllCommand}" MinWidth="90" />
            <Button Grid.Row="1" Grid.Column="2" Content="{DynamicResource String.TsServiceFilter.ClearAll}"
                    Command="{Binding ClearAllCommand}" HorizontalAlignment="Left" MinWidth="90" />
            <TextBlock Grid.Row="1" Grid.Column="3" IsVisible="{Binding ShowOutputProgress}" VerticalAlignment="Center">
                <Run Text="{Binding ProgressText}" FontWeight="Bold" /><Run Text="  " />
                <Run Text="{Binding SpeedText}" />
            </TextBlock>
        </Grid>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Services}" AutoGenerateColumns="False"
                  IsEnabled="{Binding CanSelect}" GridLinesVisibility="All" CanUserResizeColumns="True"
                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="{DynamicResource String.TsServiceFilter.Column.Keep}" Width="65">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" IsEnabled="{Binding CanExtract}"
                                      HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource String.TsServiceFilter.Column.Name}" Binding="{Binding ServiceName}" Width="150" IsReadOnly="True" />
                <DataGridTextColumn Header="{DynamicResource String.TsServiceFilter.Column.Id}" Binding="{Binding ServiceIdText}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="{DynamicResource String.TsServiceFilter.Column.Provider}" Binding="{Binding ProviderName}" Width="130" IsReadOnly="True" />
                <DataGridTextColumn Header="{DynamicResource String.TsServiceFilter.Column.Type}" Binding="{Binding ServiceTypeText}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="{DynamicResource String.TsServiceFilter.Column.PmtPid}" Binding="{Binding PmtPidText}" Width="90" IsReadOnly="True" />
                <DataGridTextColumn Header="{DynamicResource String.TsServiceFilter.Column.Tracks}" Binding="{Binding TrackSummary}" Width="260" IsReadOnly="True" />
                <DataGridTemplateColumn Header="{DynamicResource String.TsServiceFilter.Column.FileName}" Width="260">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding OutputFileName, Mode=TwoWay}" Margin="2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0" Text="{DynamicResource String.TsServiceFilter.OutputFolder}" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding OutputFolder, Mode=TwoWay}" />
            <Button Grid.Column="2" Content="{DynamicResource String.TsServiceFilter.Browse}" Command="{Binding BrowseCommand}" MinWidth="90" />
            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                <Button Content="{DynamicResource String.Cancel}" Command="{Binding CancelCommand}" Width="90" />
                <Button Content="{DynamicResource String.TsServiceFilter.Output}" Command="{Binding OutputCommand}" Width="100" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
