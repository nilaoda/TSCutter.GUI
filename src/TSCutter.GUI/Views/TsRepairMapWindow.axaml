<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:TSCutter.GUI.ViewModels"
        xmlns:models="clr-namespace:TSCutter.GUI.Models"
        xmlns:controls="clr-namespace:TSCutter.GUI.Controls"
        xmlns:local="clr-namespace:TSCutter.GUI"
        xmlns:common="clr-namespace:Classic.CommonControls;assembly=Classic.CommonControls.Avalonia"
        mc:Ignorable="d"
        x:Class="TSCutter.GUI.Views.TsRepairMapWindow"
        x:DataType="viewModels:TsRepairMapWindowViewModel"
        Title="{DynamicResource String.TsRepair.Map.Title}"
        Width="900" Height="580" MinWidth="720" MinHeight="460"
        WindowStartupLocation="CenterOwner">
    <Window.Styles>
        <Style Selector="TextBlock.mapSuccess">
            <Setter Property="Foreground" Value="{DynamicResource AppStatusSuccessForegroundBrush}" />
        </Style>
        <Style Selector="TextBlock.mapWarning">
            <Setter Property="Foreground" Value="{DynamicResource AppStatusWarningForegroundBrush}" />
        </Style>
        <Style Selector="TextBlock.mapError">
            <Setter Property="Foreground" Value="{DynamicResource AppStatusErrorForegroundBrush}" />
        </Style>
        <Style Selector="TextBlock.matrixAvailable">
            <Setter Property="Foreground" Value="{DynamicResource AppStatusSuccessForegroundBrush}" />
        </Style>
        <Style Selector="TextBlock.matrixChosen">
            <Setter Property="Foreground" Value="{DynamicResource AppRepairMapSelectionBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.matrixNone">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static common:SystemColors.GrayTextColorKey}}" />
        </Style>
        <!-- 窗口级状态样式优先级高于应用主题，因此选中态也必须在同一作用域覆盖。 -->
        <Style Selector="DataGridRow:selected TextBlock">
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static common:SystemColors.HighlightTextBrushKey}}" />
        </Style>
    </Window.Styles>
    <Grid Margin="12" RowDefinitions="Auto,*,Auto,Auto" RowSpacing="8">
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,150,42" ColumnSpacing="8">
                <RadioButton Grid.Column="0" GroupName="RepairMapDisplay"
                             Content="{DynamicResource String.TsRepair.Map.SourceMatrix}"
                             IsChecked="{Binding IsSourceMatrixDisplay, Mode=TwoWay}" />
                <RadioButton Grid.Column="1" GroupName="RepairMapDisplay"
                             Content="{DynamicResource String.TsRepair.Map.Timeline}"
                             IsChecked="{Binding IsTimelineDisplay, Mode=TwoWay}" />
                <RadioButton Grid.Column="2" GroupName="RepairMapView" Margin="10,0,0,0"
                             Content="{DynamicResource String.TsRepair.Map.Expected}"
                             IsChecked="{Binding IsExpectedView, Mode=TwoWay}" />
                <RadioButton Grid.Column="3" GroupName="RepairMapView"
                             Content="{DynamicResource String.TsRepair.Map.Actual}"
                             IsChecked="{Binding IsActualView, Mode=TwoWay}"
                             IsEnabled="{Binding HasActualResult}" />
                <TextBlock Grid.Column="4" Text="{Binding SummaryText}" VerticalAlignment="Center"
                           Margin="8,0,0,0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="5" Text="{DynamicResource String.TsRepair.Map.Zoom}"
                           VerticalAlignment="Center" IsVisible="{Binding IsTimelineDisplay}" />
                <Slider Grid.Column="6" Minimum="100" Maximum="800"
                        TickFrequency="25" SmallChange="25" LargeChange="100"
                        IsSnapToTickEnabled="True"
                        Value="{Binding ZoomPercent, Mode=TwoWay}"
                        ValueChanged="Zoom_OnValueChanged"
                        VerticalAlignment="Center" IsVisible="{Binding IsTimelineDisplay}" />
                <TextBlock Grid.Column="7" Text="{Binding ZoomDisplayText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           IsVisible="{Binding IsTimelineDisplay}" />
            </Grid>
            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                <TextBlock Grid.Column="0" Text="{DynamicResource String.TsRepair.Map.Reference}" />
                <TextBlock Grid.Column="1" Text="{Binding ReferenceFileName}" TextTrimming="CharacterEllipsis" />
                <Border Grid.Column="2" Width="14" Height="10" Background="{DynamicResource AppStatusSuccessForegroundBrush}" />
                <TextBlock Grid.Column="3" Text="{DynamicResource String.TsRepair.Map.Legend.Success}" />
                <Border Grid.Column="4" Width="14" Height="10" Background="{DynamicResource AppStatusWarningForegroundBrush}" />
                <TextBlock Grid.Column="5" Text="{DynamicResource String.TsRepair.Map.Legend.Warning}" />
                <Border Grid.Column="6" Width="14" Height="10" Background="{DynamicResource AppStatusErrorForegroundBrush}" />
                <TextBlock Grid.Column="7" Text="{DynamicResource String.TsRepair.Map.Legend.Error}" />
            </Grid>
            <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="6" IsVisible="{Binding HasBroadcastTime}">
                <TextBlock Grid.Column="0" Text="{DynamicResource String.Ts.BroadcastTime.Label}" />
                <TextBlock Grid.Column="1" Text="{Binding BroadcastTimeRangeText}" FontWeight="SemiBold" />
            </Grid>
        </Grid>

        <DataGrid x:Name="SourceMatrixGrid" Grid.Row="1"
                  ItemsSource="{Binding MatrixRows}"
                  SelectedItem="{Binding SelectedMatrixRow, Mode=TwoWay}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserReorderColumns="False" CanUserResizeColumns="True" CanUserSortColumns="False"
                  FrozenColumnCount="3" RowHeight="34" ColumnHeaderHeight="64"
                  GridLinesVisibility="All" HeadersVisibility="Column"
                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                  IsVisible="{Binding IsSourceMatrixDisplay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource String.TsRepair.Map.Matrix.Time}"
                                    Binding="{Binding TimeText}" Width="130" IsReadOnly="True" />
                <DataGridTextColumn Header="{DynamicResource String.TsRepair.Map.Matrix.Track}"
                                    Binding="{Binding TrackText}" Width="190" IsReadOnly="True" />
                <DataGridTemplateColumn Header="{DynamicResource String.TsRepair.Map.Matrix.Issue}"
                                        Width="160" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:TsRepairMapMatrixRowView">
                            <TextBlock Text="{Binding IssueText}" Margin="6,0"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                       Classes.mapSuccess="{Binding IsSuccess}"
                                       Classes.mapWarning="{Binding IsWarning}"
                                       Classes.mapError="{Binding IsError}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <ClassicBorderDecorator Grid.Row="1" BorderThickness="1" BorderStyle="Sunken" Padding="0"
                                IsVisible="{Binding IsTimelineDisplay}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource {x:Static common:SystemColors.WindowColorKey}}">
                <Grid ColumnDefinitions="230,*">
                    <Border Grid.Column="0" BorderBrush="{DynamicResource {x:Static common:SystemColors.WindowFrameColorKey}}"
                            BorderThickness="0,0,1,0"
                            Background="{DynamicResource {x:Static common:SystemColors.WindowColorKey}}">
                        <Grid RowDefinitions="32,Auto">
                            <TextBlock Grid.Row="0" Text="{DynamicResource String.TsRepair.Map.Track}"
                                       Margin="8,0" VerticalAlignment="Center" FontWeight="Bold" />
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Tracks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:TsRepairMapTrackView">
                                        <Border Height="38" BorderBrush="{DynamicResource {x:Static common:SystemColors.GrayTextColorKey}}"
                                                BorderThickness="0,1,0,0" Padding="8,0">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                                                    <TextBlock Text="{Binding DisplayText}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                               Foreground="{DynamicResource {x:Static common:SystemColors.GrayTextColorKey}}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource String.TsRepair.Map.NotSelectedMark}"
                                                           IsVisible="{Binding IsSelected, Converter={x:Static local:App.InverseBoolConverter}}"
                                                           Foreground="{DynamicResource {x:Static common:SystemColors.GrayTextColorKey}}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                    <ScrollViewer x:Name="TimelineScrollViewer" Grid.Column="1"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                  HorizontalContentAlignment="Left"
                                  SizeChanged="TimelineScrollViewer_OnSizeChanged">
                        <controls:TsRepairMapTimeline x:Name="RepairTimeline" HorizontalAlignment="Left"
                                                      Tracks="{Binding Tracks}"
                                                      DurationSeconds="{Binding DurationSeconds}"
                                                      SelectedRegion="{Binding SelectedRegion, Mode=TwoWay}"
                                                      BackgroundBrush="{DynamicResource {x:Static common:SystemColors.WindowColorKey}}"
                                                      GridBrush="{DynamicResource {x:Static common:SystemColors.GrayTextColorKey}}"
                                                      TextBrush="{DynamicResource {x:Static common:SystemColors.WindowTextColorKey}}"
                                                      SuccessBrush="{DynamicResource AppStatusSuccessForegroundBrush}"
                                                      WarningBrush="{DynamicResource AppStatusWarningForegroundBrush}"
                                                      ErrorBrush="{DynamicResource AppStatusErrorForegroundBrush}"
                                                      MutedBrush="{DynamicResource {x:Static common:SystemColors.GrayTextColorKey}}"
                                                      SelectionBrush="{DynamicResource AppRepairMapSelectionBrush}"
                                                      TooltipBackgroundBrush="{DynamicResource {x:Static common:SystemColors.InfoColorKey}}"
                                                      TooltipTextBrush="{DynamicResource {x:Static common:SystemColors.InfoTextColorKey}}"
                                                      TooltipBorderBrush="{DynamicResource {x:Static common:SystemColors.WindowFrameColorKey}}"
                                                      TimeLabel="{DynamicResource String.TsRepair.Map.ZeroBasedTime}" />
                    </ScrollViewer>
                </Grid>
            </ScrollViewer>
        </ClassicBorderDecorator>

        <ClassicBorderDecorator Grid.Row="2" BorderThickness="1" BorderStyle="Etched" Padding="8">
            <Grid RowDefinitions="Auto,*" RowSpacing="6">
                <TextBlock Grid.Row="0" Text="{DynamicResource String.TsRepair.Map.SelectedRegion}"
                           FontWeight="Bold" />
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="8" RowSpacing="5">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource String.TsRepair.Map.Detail.Track}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedRegion.TrackText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource String.TsRepair.Map.Detail.Status}" />
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding SelectedRegion.StatusText}" FontWeight="SemiBold"
                               Classes.mapSuccess="{Binding IsSelectedSuccess}"
                               Classes.mapWarning="{Binding IsSelectedWarning}"
                               Classes.mapError="{Binding IsSelectedError}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource String.TsRepair.Map.Detail.Issue}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedRegion.IssueText}" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{DynamicResource String.TsRepair.Map.Detail.Time}" />
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SelectedRegion.TimeText}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource String.TsRepair.Map.Detail.Source}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedSourceText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{DynamicResource String.TsRepair.Map.Detail.Position}" />
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding SelectedRegion.PositionText}" TextTrimming="CharacterEllipsis" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource String.TsRepair.Map.Detail.Match}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedMatchText}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="{DynamicResource String.TsRepair.Map.Detail.Packets}" />
                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding SelectedPacketText}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource String.Ts.BroadcastTime.Label}"
                               IsVisible="{Binding SelectedRegion.HasBroadcastTime}" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                               Text="{Binding SelectedRegion.BroadcastTimeText}"
                               IsVisible="{Binding SelectedRegion.HasBroadcastTime}" />
                </Grid>
            </Grid>
        </ClassicBorderDecorator>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0" Text="{Binding HintText}" TextWrapping="Wrap"
                       Foreground="{DynamicResource {x:Static common:SystemColors.GrayTextColorKey}}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="{DynamicResource String.TsRepair.Map.Close}" Width="100"
                    Click="Close_OnClick" />
        </Grid>
    </Grid>
</Window>
